# Client Env Vars (Add to Vercel for frontend)
VITE_API_URL=http://localhost:5000/api

# Server Env Vars (Add to Vercel for backend)
PORT=5000
CLIENT_URL=http://localhost:5173

# Database (Supabase PostgreSQL Connection String)
DATABASE_URL=

# Auth
JWT_SECRET=your_super_secret_jwt_key
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=<a second, different secret — do not reuse JWT_SECRET>
JWT_REFRESH_EXPIRES_IN=7d

# Supabase Storage (File Uploads)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_LISTING_PHOTOS_BUCKET=listing-photos

# Email (SMTP) — for password reset emails
# Use any SMTP provider: Gmail, SendGrid, Mailgun, Resend, etc.
# Gmail example: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_SECURE=false
# Use an App Password (not your real Gmail password) if using Gmail with 2FA
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=FoodRescue <your-email@gmail.com>
