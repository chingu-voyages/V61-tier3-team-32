# Client Env Vars (Add to Vercel for frontend)
VITE_API_URL=http://localhost:5000/api

# Server Env Vars (Add to Vercel for backend)
PORT=5000
CLIENT_URL=http://localhost:5173

# Database (Supabase PostgreSQL Connection String)
DATABASE_URL=

# Auth
JWT_SECRET=your_super_secret_jwt_key
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=<a second, different secret — do not reuse JWT_SECRET>
JWT_REFRESH_EXPIRES_IN=7d

# Supabase Storage (File Uploads)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_LISTING_PHOTOS_BUCKET=listing-photos
